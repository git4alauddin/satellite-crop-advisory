# Copy to .env at repository root before docker compose up
# Example Linux/macOS:
# GEE_CREDENTIALS_DIR=/home/<user>/.config/earthengine
# Example Windows (PowerShell style path):
# GEE_CREDENTIALS_DIR=C:/Users/<user>/.config/earthengine

GEE_PROJECT_ID=your-gcp-project-id
GEE_CREDENTIALS_DIR=./.gee_credentials
